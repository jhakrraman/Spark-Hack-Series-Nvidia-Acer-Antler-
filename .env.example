# ----- VLM backend selector -----
# Options: lmstudio | nim | poi-brain
# - lmstudio: original path, calls local LM Studio server with Gemma 4
# - nim: calls an NVIDIA NIM container (OpenAI-compatible) on the DGX
# - poi-brain: routes frames through poi-brain FastAPI on the DGX (risk-aware)
POI_VLM_BACKEND=poi-brain

# ----- poi-brain FastAPI service on the DGX -----
# HTTP URL reachable from the Next.js server (used by server actions).
POI_BRAIN_URL=http://dgx.tailnet.ts.net:8080
# HTTP URL reachable from the browser (used by client hooks / risk client).
# Must be publicly reachable OR proxied via app/api/risk/heatmap/route.ts.
NEXT_PUBLIC_POI_BRAIN_URL=http://dgx.tailnet.ts.net:8080
# Optional websocket URL for the frame push channel (fallback path).
POI_BRAIN_WS=ws://dgx.tailnet.ts.net:8765/ws/frames

# ----- NVIDIA NIM (direct, if not using poi-brain) -----
# OpenAI-compatible endpoint served by the NIM container.
NIM_BASE_URL=http://dgx.tailnet.ts.net:8000/v1
NIM_MODEL=meta/llama-3.2-11b-vision-instruct
NIM_API_KEY=nim

# ----- LM Studio (local Gemma 4, fallback) -----
# Start LM Studio, load a Gemma 4 VLM, click "Start Server" in the Developer tab.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=google/gemma-4-26b-a4b
LMSTUDIO_API_KEY=lm-studio

# ----- Supabase (auth + db, optional) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----- Resend (email alerts) -----
RESEND_API_KEY=

# ----- Vercel Blob (archive storage, optional) -----
BLOB_READ_WRITE_TOKEN=

# ----- OpenAI (assistant chatbot only, optional) -----
OPENAI_API_KEY=
