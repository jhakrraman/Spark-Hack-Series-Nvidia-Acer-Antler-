# --- NVIDIA NIM (primary VLM) ---
NIM_BASE_URL=http://localhost:8000/v1
NIM_MODEL=meta/llama-3.2-11b-vision-instruct
NIM_API_KEY=nim
NIM_WARMUP_ON_STARTUP=true

VLM_BACKEND=nim

# --- NYC Open Data (SODA) ---
# Get a free token at https://data.cityofnewyork.us/profile/edit/developer_settings
SODA_APP_TOKEN=
SODA_TIMEOUT_S=60.0

# Per-dataset row caps for bootstrap ingest. Dev-scale defaults produce a
# meaningful training frame in 2-5 min even without a SODA app token. On the
# DGX with a token, bump higher for full-fat coverage:
#   NYPD_HISTORIC_LIMIT=500000
#   NYPD_YTD_LIMIT=300000
#   COLLISIONS_LIMIT=300000
#   SERVICE_311_LIMIT=300000
NYPD_HISTORIC_LIMIT=250000
NYPD_YTD_LIMIT=150000
COLLISIONS_LIMIT=150000
SERVICE_311_LIMIT=200000
DOT_CAMERAS_LIMIT=10000

# --- Storage ---
DATA_ROOT=/data/poi
PARQUET_ROOT=/data/poi/parquet
MODELS_ROOT=/data/poi/models
CACHE_ROOT=/data/poi/cache

# --- Camera ingestion ---
WEBCAMS_BASE=https://webcams.nyctmc.org
CAMERA_POLL_INTERVAL_S=3.0
CAMERA_SUBSET_SIZE=12
# Optional: comma-separated camera IDs to force-include (leave blank for default top-12)
# CAMERA_MANUAL_SUBSET=nyc-times-sq,nyc-union-sq

# --- Risk model ---
H3_RESOLUTION=9
PREDICTION_WINDOW_MINUTES=15
MODEL_VERSION=cuml-xgb-v0

# --- RAPIDS feature flags ---
ENABLE_RAPIDS=true
ENABLE_CUSPATIAL=true
ENABLE_CUGRAPH=false
ENABLE_CUOPT=false

# --- ML backend ---
# auto = cuml-xgb on NVIDIA+RAPIDS, torch on Mac/MPS, sklearn otherwise
# Override with: cuml-xgb | torch | sklearn
ML_BACKEND=auto
# torch-specific device. auto = cuda > mps > cpu
# Override with: cuda | mps | cpu
TORCH_DEVICE=auto

# --- Retrieval ---
RETRIEVAL_BACKEND=faiss
RETRIEVAL_TOP_K=5
RETRIEVAL_RADIUS_M=500.0
RETRIEVAL_MAX_DAYS_AGO=30

# --- Service ---
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
CORS_ALLOW_ORIGINS=["*"]
